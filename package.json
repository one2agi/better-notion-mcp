{
  "name": "@faize/better-notion-mcp",
  "mcpName": "io.github.faize/better-notion-mcp",
  "keywords": [
    "notion",
    "api",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "composite-tools",
    "claude",
    "cursor",
    "copilot",
    "antigravity",
    "codex",
    "opencode"
  ],
  "version": "3.7.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.2.21",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -build && node scripts/build-cli.js",
    "dev": "tsx watch scripts/start-server.ts",
    "dev:http": "TRANSPORT_MODE=http tsx watch scripts/start-server.ts",
    "test": "vitest --passWithNoTests",
    "test:watch": "vitest watch",
    "test:full": "vitest run tests/live/*.full.test.ts",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "check": "biome check . && bun run type-check",
    "check:fix": "biome check --write . && bun run type-check",
    "prepublishOnly": "bun run build",
    "docker:build": "docker build -t faize/better-notion-mcp:latest .",
    "docker:push": "docker push faize/better-notion-mcp:latest",
    "docker:run": "docker run --rm -i -e NOTION_TOKEN faize/better-notion-mcp:latest",
    "cf:dryrun": "node scripts/cf-deploy.mjs --dry-run",
    "cf:deploy": "node scripts/cf-deploy.mjs"
  },
  "bin": {
    "better-notion-mcp": "bin/cli.mjs"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "files": [
    "build/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@n24q02m/mcp-core": "^1.18.1",
    "@notionhq/client": "^5.22.0",
    "zod": "^4.4.3"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@cloudflare/workers-types": "^4.20260701.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "description": "Better MCP server for Notion API with composite tools optimized for AI agents",
  "main": "build/src/init-server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/faize/better-notion-mcp.git"
  },
  "author": "faize",
  "bugs": {
    "url": "https://github.com/faize/better-notion-mcp/issues"
  },
  "homepage": "https://github.com/faize/better-notion-mcp#readme"
}
