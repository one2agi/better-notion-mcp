{
  "name": "better-notion-mcp",
  "description": "Markdown-first Notion API integration — 8 composite tools, ~95% coverage",
  "version": "2.35.0-beta.6",
  "userConfig": {
    "NOTION_TOKEN": {
      "type": "string",
      "title": "Notion integration token",
      "description": "From https://www.notion.so/my-integrations (starts with ntn_)",
      "sensitive": true,
      "required": true
    }
  },
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/better-notion-mcp",
  "mcpServers": {
    "better-notion-mcp": {
      "command": "npx",
      "args": ["--yes", "@n24q02m/better-notion-mcp@latest"],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "NOTION_TOKEN": "${user_config.NOTION_TOKEN}"
      }
    }
  }
}
